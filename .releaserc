{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^version = \".*\"/version = \"${nextRelease.version}\"/' crates/wakeup/Cargo.toml crates/wakeup-core/Cargo.toml"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "crates/wakeup/Cargo.toml",
          "crates/wakeup-core/Cargo.toml",
          "Cargo.lock"
        ],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ]
  ]
}
